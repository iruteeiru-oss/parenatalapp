<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Setup"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete all steps to activate monitoring"
            android:textSize="14sp"
            android:textColor="#6B6B6B"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"/>

        <!-- Step 1: Parent ID -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardParentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 1 — Parent ID"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvStep1Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter the ID provided by the parent app"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etParentId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter Parent ID"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/bg_input"
                    android:inputType="text"/>

                <Button
                    android:id="@+id/btnSaveParentId"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Save ID"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 2: Accessibility -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 2 — Accessibility"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvStep2Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable System Accessibility Helper in settings"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Open Accessibility Settings"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 3: Battery -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 3 — Battery"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvStep3Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disable battery optimization so the service runs 24/7"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnBatteryOptimization"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Disable Battery Optimization"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 4: Location Tracking -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 4 — Location Permission"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvStep4Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant location permissions to share coordinates in emergencies"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableLocation"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Grant Location Access"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 5: Notification Access -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 5 — Notification Access"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvStep5Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Notification Access to capture messages in background"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableNotification"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Grant Notification Access"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvFinalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ Setup Incomplete"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvFinalSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete all 5 steps above"
                    android:textSize="13sp"
                    android:textColor="#A0A0A0"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
