<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="#F8F8F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardian"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parental Monitor Onboarding"
        android:textSize="15sp"
        android:textColor="#6B6B6B"
        android:layout_marginBottom="40dp"/>

    <!-- Option A: Enter existing code -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter Your Room / Parent ID"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etParentId"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="e.g. GD-5F39-1E"
        android:textSize="15sp"
        android:padding="14dp"
        android:background="@drawable/bg_input"
        android:inputType="textCapCharacters"
        android:layout_marginBottom="12dp"/>

    <!-- Option B: Generate new code -->
    <TextView
        android:id="@+id/btnGenerateCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Generate a New Random Code"
        android:textColor="#1976D2"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:layout_marginBottom="32dp"/>

    <!-- Connect Button -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Connect &amp; Enter Dashboard"
        android:textSize="16sp"
        android:backgroundTint="#1A1A1A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <!-- Helpful Instruction Panel -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        android:backgroundTint="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 How to pair devices:"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Generate or type a unique code above and tap 'Connect'.\n2. Open the Guardian app on your child's phone.\n3. Select 'Child Phone' and enter this exact same code under Step 1.\n4. Both devices will instantly link into the same secure chat room!"
                android:textSize="12sp"
                android:textColor="#6B6B6B"
                android:lineSpacingMultiplier="1.3"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#D32F2F"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

</LinearLayout>
