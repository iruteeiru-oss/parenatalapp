<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="28dp"
    android:background="#0F0F0F">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛡"
        android:textSize="48sp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardian"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parent Dashboard Setup"
        android:textSize="14sp"
        android:textColor="#8A8A8A"
        android:layout_marginBottom="40dp"/>

    <!-- Enter Code -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pairing Code"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#BBBBBB"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etParentId"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="e.g. GD-5F39-1E"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@drawable/bg_input_dark"
        android:inputType="textCapCharacters"
        android:layout_marginBottom="12dp"/>

    <!-- Generate Code Link -->
    <TextView
        android:id="@+id/btnGenerateCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Generate Random Code"
        android:textColor="#4DA6FF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:layout_marginBottom="28dp"/>

    <!-- Connect Button -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Connect &amp; Start Monitoring"
        android:textSize="15sp"
        android:backgroundTint="#4DA6FF"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="28dp"/>

    <!-- Instructions Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1E1E1E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 How to pair devices"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Generate or type a pairing code above\n2. Tap 'Connect &amp; Start Monitoring'\n3. On the child's phone, open Guardian\n4. Select 'Child Phone' → enter this same code\n5. Grant all permissions on the child's phone\n6. Data will start flowing to this dashboard!"
                android:textSize="12sp"
                android:textColor="#8A8A8A"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:indeterminateTint="#4DA6FF"/>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF6B6B"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

</LinearLayout>
