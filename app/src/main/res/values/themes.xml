<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.DeviceGuardian" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Parent Theme. -->
    <style name="Theme.Theme.Guardian" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#1A1A1A</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#03DAC5</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">#1A1A1A</item>
    </style>

    <!-- Fallback style for Theme.Guardian if reference has double namespace -->
    <style name="Theme.Guardian" parent="Theme.Theme.Guardian"/>

    <!-- Filter Chip Style -->
    <style name="FilterChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">#1A1A1A</item>
        <item name="chipStrokeColor">#E0E0E0</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
</resources>
