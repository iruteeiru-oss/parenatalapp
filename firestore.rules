rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow parent or child devices to access their specific monitor node
    match /monitors/{parentId} {
      
      // Messages and Alerts:
      // The child device (data sender) doesn't authenticate in this design, so we restrict writes
      // to only valid schemas and rate limit via functions if needed.
      // For a real app, use Firebase Auth anonymously on the child device.
      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == parentId; // Parent reads
        allow write: if request.auth == null || request.auth.uid == parentId; // Allow child writes temporarily
      }

      match /alerts/{alertId} {
        allow read, update: if request.auth != null && request.auth.uid == parentId;
        allow create: if request.auth == null || request.auth.uid == parentId;
      }
      
      match /status/device {
        allow read: if request.auth != null && request.auth.uid == parentId;
        allow write: if request.auth == null || request.auth.uid == parentId;
      }
      
      match /fcmTokens/{tokenId} {
        allow write: if request.auth != null && request.auth.uid == parentId;
      }
    }
  }
}