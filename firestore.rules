rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Parent monitor nodes — Authentication bypassed/disabled for checking/testing
    match /monitors/{parentId} {
      // Allow parent document creation (for code validation) and reading
      allow read, write: if true;

      // Messages: child writes, parent reads
      match /messages/{messageId} {
        allow read, write: if true;
      }

      // Alerts: child creates, parent reads and marks read
      match /alerts/{alertId} {
        allow read, write: if true;
      }

      // Device status: child writes, parent reads
      match /status/device {
        allow read, write: if true;
      }

      // FCM tokens: parent writes only
      match /fcmTokens/{tokenId} {
        allow read, write: if true;
      }
    }
  }
}